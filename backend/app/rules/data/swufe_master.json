{
  "school": "西南财经大学",
  "degree": "master",
  "version": "swufe-2007-revised-demo",
  "page_setup": {
    "top_cm": 3.9,
    "bottom_cm": 3.4,
    "left_cm": 3.45,
    "right_cm": 3.45
  },
  "styles": {
    "title": {
      "font_family": "STZhongsong",
      "font_size_pt": 18,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.37,
      "first_line_indent_chars": 0
    },
    "heading_1": {
      "font_family": "STZhongsong",
      "font_size_pt": 22,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.37,
      "first_line_indent_chars": 0
    },
    "heading_2": {
      "font_family": "SimHei",
      "font_size_pt": 15,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.37,
      "first_line_indent_chars": 0
    },
    "body": {
      "font_family": "SimSun",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "justify",
      "line_spacing": 1.37,
      "first_line_indent_chars": 2
    },
    "caption": {
      "font_family": "SimHei",
      "font_size_pt": 10.5,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.37,
      "first_line_indent_chars": 0
    }
  },
  "required_sections": [
    {"name": "Cover", "aliases": ["封面", "扉页"], "required": false, "order": 1},
    {"name": "Originality Statement", "aliases": ["声明", "原创性及知识产权声明"], "required": false, "order": 2},
    {"name": "Chinese Abstract", "aliases": ["摘要", "中文摘要"], "required": true, "order": 3},
    {"name": "English Abstract", "aliases": ["Abstract", "ABSTRACT", "英文摘要"], "required": true, "order": 4},
    {"name": "Table of Contents", "aliases": ["目录"], "required": true, "order": 5},
    {"name": "Introduction", "aliases": ["前言", "引言", "导论", "绪论"], "required": true, "order": 6},
    {"name": "Body", "aliases": ["正文", "第1章", "第一章"], "required": true, "order": 7},
    {"name": "References", "aliases": ["注释及参考文献", "参考文献"], "required": true, "order": 8},
    {"name": "Appendix", "aliases": ["附录"], "required": false, "order": 9},
    {"name": "Postscript", "aliases": ["后记"], "required": false, "order": 10},
    {"name": "Acknowledgements", "aliases": ["致谢"], "required": false, "order": 11},
    {"name": "Research Outputs", "aliases": ["在读期间科研成果目录"], "required": false, "order": 12}
  ],
  "page_numbers": {
    "enabled": true,
    "start_at_body": true,
    "body_format": "arabic"
  },
  "captions": {
    "figure": "图",
    "table": "表"
  },
  "validators": [
    "required_sections",
    "page_margins",
    "heading_hierarchy",
    "caption_format",
    "toc_presence"
  ]
}
